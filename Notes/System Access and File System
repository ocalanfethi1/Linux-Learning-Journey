- root is the most powerful account which has all access to all command and files
    calvin@localhost:~$ su -
    root@localhost:~# 

    root@localhost:~# whoami
    root
 
# changing root PASSWORD 
- while the user is root, the user change the password whihs is for becoming root again
    root@localhost:~# passwd userid
    New password: ******
    Retype new password : ******
    passwd: password updated successfully

# Navigating file system 
  1- pwd
  - stands for print working directory, to know where are you like in which path
      root@localhost:/home/calvin# pwd
      /home/calvin
  2- ls
  - stands for list
      root@localhost:/home/calvin# ls
      Desktop    Documents    Pictures    Music
  - ls -l , ls -ltr those are for listing in more detail form 
  3- cd
  - stands for change directory
      root@localhost:/home/calvin# cd Desktop
      root@localhost:/home/calvin/Desktop#

      root@localhost:/home/calvin# cd ..
      root@localhost:/home/#

      root@localhost:/home/calvin# cd
      root@localhost:~#

      root@localhost:~# cd /home/calvin/pictures
      root@localhost:/home/calvin/Pictures# 

